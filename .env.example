# WNCORE Radio - Environment Variables
# Copy this to .env and fill in your values

# ── SUPABASE CONFIG (for admin panel) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# ── ADMIN PANEL ──
ADMIN_PASSWORD_HASH=your_hashed_password_here

# ── API CONFIG ──
RADIO_BROWSER_API=https://all.api.radio-browser.info/json
API_CACHE_TTL=3600

# ── MONITORING ──
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=info

# ── FEATURES ──
ENABLE_ARG_MODE=true
ENABLE_ADMIN_PANEL=true
ENABLE_SIGNAL_LOST=true

# ── DEPLOYMENT ──
VERCEL_ENV=production
ENVIRONMENT=production
